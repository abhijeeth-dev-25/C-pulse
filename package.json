{
  "name": "c-pulse",
  "displayName": "C-Pulse",
  "publisher": "abhijeeth-dev-25",
  "description": "C Data Structures & Algorithms Visualizer",
  "version": "0.0.2",
  "icon": "images/icon.jpg",
  "keywords": [
    "c",
    "visualization",
    "debugger",
    "memory",
    "pointers"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/abhijeeth-dev-25/C-pulse.git"
  },
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Other",
    "Education",
    "Debuggers"
  ],
  "activationEvents": [
    "onLanguage:c"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "c-pulse.start",
        "title": "C-Pulse: Visualize",
        "icon": "$(play-circle)"
      }
    ],
    "keybindings": [
      {
        "command": "c-pulse.start",
        "key": "ctrl+shift+p",
        "mac": "cmd+shift+p",
        "when": "resourceLangId == c"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "watch:webview": "cd webview-ui && npm run build -- --watch",
    "dev": "concurrently -c \"cyan,magenta\" \"npm run watch\" \"npm run watch:webview\"",
    "build:extension": "webpack --mode production --devtool hidden-source-map",
    "build:webview": "cd webview-ui && npm run build",
    "build": "npm run build:extension && npm run build:webview",
    "package": "npm run build",
    "clean": "rm -rf dist out webview-ui/dist",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.70.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.3",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1"
  }
}